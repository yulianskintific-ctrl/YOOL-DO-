# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE APPS SCRIPT WEB APP PROXIES
# Customize these separate script URLs to use different sheets/scripts for each module (for Node backend).
SALES_DATA_SCRIPT_URL=""          # For Sell In, Sell Through
INCENTIVES_INTERNAL_SCRIPT_URL="" # For Incentives SPV Internal
INCENTIVES_EXCLUSIVE_SCRIPT_URL="" # For Incentives SPV Exclusive
INCENTIVES_SE_SCRIPT_URL=""       # For Incentives SE
SELL_OUT_SCRIPT_URL="https://script.google.com/macros/s/AKfycbyDS6ZPtUffLDNVieh-hCG4e2z6vDOzS-MI891J_xjDRIK5yJ8rXsaYFuqVqJ-C5fqOfg/exec" # For dedicated Sell Out Google Sheet
SKU_FOCUS_SCRIPT_URL="https://script.google.com/macros/s/AKfycbxwAD5bkdKM_bJ4v25FQT9neXHRXMnXqzlIUaKje1xCqPqB9wbrn40EbcxSDtEXaMgUuw/exec"          # For SKU Focus Google Sheet ("SKT Product Focus Jun Kal")

# VERCEL / STATIC HOST CLIENT-SIDE OVERRIDES
# If deploying statically (e.g. on Vercel without active Node/Express daemons),
# set these VITE_ prefixed environment variables in your Vercel Dashboard.
VITE_SCRIPT_URL=""
VITE_INCENTIVES_INTERNAL_SCRIPT_URL=""
VITE_INCENTIVES_EXCLUSIVE_SCRIPT_URL=""
VITE_INCENTIVES_SE_SCRIPT_URL=""
VITE_SELL_OUT_SCRIPT_URL="https://script.google.com/macros/s/AKfycbyDS6ZPtUffLDNVieh-hCG4e2z6vDOzS-MI891J_xjDRIK5yJ8rXsaYFuqVqJ-C5fqOfg/exec"
VITE_SKU_FOCUS_SCRIPT_URL="https://script.google.com/macros/s/AKfycbxwAD5bkdKM_bJ4v25FQT9neXHRXMnXqzlIUaKje1xCqPqB9wbrn40EbcxSDtEXaMgUuw/exec"


